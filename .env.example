# Supabase project (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only, bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of this app (required)
# Used to build absolute links in emails (invites, password reset, auth callback).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (required for candidate invites, password reset emails, contact form)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Internal Ops Console (ITOC) admin allowlist.
# Comma-separated emails treated as superadmin bootstrap access.
# INTERNAL_ADMIN_EMAILS takes precedence over ADMIN_EMAILS if both are set.
INTERNAL_ADMIN_EMAILS=
ADMIN_EMAILS=

# Public contact form recipient.
# CONTACT_TO_EMAIL takes precedence over BUSINESS_EMAIL if both are set.
# Falls back to contact@intelligencestest.com if neither is set.
CONTACT_TO_EMAIL=
BUSINESS_EMAIL=
