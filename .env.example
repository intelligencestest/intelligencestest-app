# Supabase project (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only, bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of this app (required)
# Used to build absolute links in emails (invites, password reset, auth callback).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (required for candidate invites, password reset emails, contact form)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Optional cron protection. Use this as a Bearer token when calling
# /api/cron/trial-emails from the VPS scheduler.
CRON_SECRET=

# Optional. Powers the client-brief PDF's executive-summary narrative
# (lib/claude.ts, app/api/reports/client-brief/route.ts). Without it, that
# route falls back to a deterministic templated paragraph instead of failing.
ANTHROPIC_API_KEY=

# Internal Ops Console (ITOC) admin allowlist.
# Comma-separated emails treated as superadmin bootstrap access.
# INTERNAL_ADMIN_EMAILS takes precedence over ADMIN_EMAILS if both are set.
INTERNAL_ADMIN_EMAILS=
ADMIN_EMAILS=

# Optional comma-separated host allowlist for agency logo images in PDF output.
# Built-in allowed hosts: intelligencestest.com, www.intelligencestest.com,
# app.intelligencestest.com, NEXT_PUBLIC_SITE_URL host, and
# NEXT_PUBLIC_SUPABASE_URL host.
ALLOWED_LOGO_IMAGE_HOSTS=

# Public contact form recipient.
# CONTACT_TO_EMAIL takes precedence over BUSINESS_EMAIL if both are set.
# Falls back to contact@intelligencestest.com if neither is set.
CONTACT_TO_EMAIL=
BUSINESS_EMAIL=

# PayPal subscriptions (optional during launch)
# The client ID is public and used by the browser SDK. Never expose PAYPAL_SECRET.
# Create PayPal subscription plans that match current pricing:
# Starter: EUR 49/month
# Professional: EUR 149/month
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_STARTER_PLAN_ID=
NEXT_PUBLIC_PAYPAL_PROFESSIONAL_PLAN_ID=

# Server-side PayPal credentials, used later for webhook/subscription verification.
# PAYPAL_MODE=sandbox will prefer the sandbox keys below.
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_SANDBOX_CLIENT_ID=
PAYPAL_SANDBOX_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_STARTER_PLAN_ID=
PAYPAL_PROFESSIONAL_PLAN_ID=
# Optional mode-specific plan IDs if you keep sandbox and live plans side by side.
PAYPAL_SANDBOX_STARTER_PLAN_ID=
PAYPAL_SANDBOX_PROFESSIONAL_PLAN_ID=
PAYPAL_LIVE_STARTER_PLAN_ID=
PAYPAL_LIVE_PROFESSIONAL_PLAN_ID=
